<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CatAPIfetcher.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CatAPIfetcher.Views"
    Title="CatAPIfetcher"
    Shell.TabBarBackgroundColor="White"
    Shell.TabBarForegroundColor="#4682B4"
    Shell.TabBarUnselectedColor="#95A5A6"
    Shell.TabBarTitleColor="#2C3E50">

    <Shell.Resources>
        <ResourceDictionary>
            <Color x:Key="Primary">#4682B4</Color>
            <Color x:Key="Secondary">#95A5A6</Color>
            <Color x:Key="Accent">#2C3E50</Color>

            <Style TargetType="TabBar" ApplyToDerivedTypes="True">
                <Setter Property="Shell.TabBarBackgroundColor" Value="White"/>
                <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource Primary}"/>
                <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource Accent}"/>
                <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource Secondary}"/>
            </Style>
        </ResourceDictionary>
    </Shell.Resources>

    <TabBar>
        <ShellContent
            Title="Cats"
            ContentTemplate="{DataTemplate local:CatsListPage}"
            Route="CatsListPage" />

        <ShellContent
            Title="My Cats"
            ContentTemplate="{DataTemplate local:MyCatsPage}"
            Route="MyCatsPage" />

        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate local:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

</Shell>
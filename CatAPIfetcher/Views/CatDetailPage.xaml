<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CatAPIfetcher.Views.CatDetailPage"
             Title="Cat Detail">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Frame CornerRadius="15" Padding="0" HasShadow="True">
                <Image 
                    x:Name="CatImage"
                    Aspect="AspectFill"
                    HeightRequest="400"/>
            </Frame>

            <Label x:Name="CatNameLabel"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,10,0,10"/>

            <Grid ColumnDefinitions="120,*" RowSpacing="10" ColumnSpacing="10">

                <Label Grid.Row="0" Grid.Column="0" Text="ID:" FontAttributes="Bold" VerticalOptions="Start"/>
                <Label Grid.Row="0" Grid.Column="1" x:Name="IdLabel" VerticalOptions="Start"/>

                <Label Grid.Row="1" Grid.Column="0" Text="Breed:" FontAttributes="Bold" VerticalOptions="Start"/>
                <Label Grid.Row="1" Grid.Column="1" x:Name="BreedLabel" VerticalOptions="Start"/>

                <Label Grid.Row="2" Grid.Column="0" Text="Origin:" FontAttributes="Bold" VerticalOptions="Start"/>
                <Label Grid.Row="2" Grid.Column="1" x:Name="OriginLabel" VerticalOptions="Start"/>

                <Label Grid.Row="3" Grid.Column="0" Text="Temperament:" FontAttributes="Bold" VerticalOptions="Start"/>
                <Label Grid.Row="3" Grid.Column="1" x:Name="TemperamentLabel" VerticalOptions="Start" LineBreakMode="WordWrap"/>

                <Label Grid.Row="4" Grid.Column="0" Text="Life Span:" FontAttributes="Bold" VerticalOptions="Start"/>
                <Label Grid.Row="4" Grid.Column="1" x:Name="LifeSpanLabel" VerticalOptions="Start"/>

                <Label Grid.Row="5" Grid.Column="0" Text="Width:" FontAttributes="Bold" VerticalOptions="Start"/>
                <Label Grid.Row="5" Grid.Column="1" x:Name="WidthLabel" VerticalOptions="Start"/>

                <Label Grid.Row="6" Grid.Column="0" Text="Height:" FontAttributes="Bold" VerticalOptions="Start"/>
                <Label Grid.Row="6" Grid.Column="1" x:Name="HeightLabel" VerticalOptions="Start"/>

                <Label Grid.Row="7" Grid.Column="0" Text="Local Only:" FontAttributes="Bold" VerticalOptions="Start"/>
                <Label Grid.Row="7" Grid.Column="1" x:Name="LocalOnlyLabel" VerticalOptions="Start"/>

                <Label Grid.Row="8" Grid.Column="0" Text="Created:" FontAttributes="Bold" VerticalOptions="Start"/>
                <Label Grid.Row="8" Grid.Column="1" x:Name="CreatedLabel" VerticalOptions="Start"/>

            </Grid>

            <Label Text="Description:" FontAttributes="Bold" FontSize="18" Margin="0,10,0,5"/>
            <Label x:Name="DescriptionLabel" TextColor="Gray" LineBreakMode="WordWrap"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CatAPIfetcher.Views.CatDetailPage"
             Title="Cat Detail"
             BackgroundColor="AliceBlue">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="20">

            <Frame CornerRadius="20" 
                   Padding="0" 
                   HasShadow="True" 
                   BackgroundColor="White"
                   BorderColor="Transparent">
                <Image 
                    x:Name="CatImage"
                    Aspect="AspectFit"
                    HeightRequest="350"/>
            </Frame>

            <Frame CornerRadius="15" 
                   Padding="15" 
                   HasShadow="False" 
                   BackgroundColor="White"
                   BorderColor="Transparent">
                <Label x:Name="CatNameLabel"
                       FontSize="32"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#2C3E50"/>
            </Frame>

            <Frame CornerRadius="15" 
                   Padding="20" 
                   HasShadow="False" 
                   BackgroundColor="White"
                   BorderColor="Transparent">
                <Grid ColumnDefinitions="140,*" 
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                      RowSpacing="15" 
                      ColumnSpacing="15">

                    <Label Grid.Row="0" Grid.Column="0" 
                           Text="🆔 ID:" 
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="#34495E"
                           VerticalOptions="Start"/>
                    <Label Grid.Row="0" Grid.Column="1" 
                           x:Name="IdLabel" 
                           FontSize="14"
                           TextColor="#8B7355"
                           VerticalOptions="Start"
                           LineBreakMode="WordWrap"/>

                    <Label Grid.Row="1" Grid.Column="0" 
                           Text="🐱 Breed:" 
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="#34495E"
                           VerticalOptions="Start"/>
                    <Label Grid.Row="1" Grid.Column="1" 
                           x:Name="BreedLabel" 
                           FontSize="14"
                           TextColor="#8B7355"
                           VerticalOptions="Start"/>

                    <Label Grid.Row="2" Grid.Column="0" 
                           Text="🌍 Origin:" 
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="#34495E"
                           VerticalOptions="Start"/>
                    <Label Grid.Row="2" Grid.Column="1" 
                           x:Name="OriginLabel" 
                           FontSize="14"
                           TextColor="#8B7355"
                           VerticalOptions="Start"/>

                    <Label Grid.Row="3" Grid.Column="0" 
                           Text="😺 Temperament:" 
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="#34495E"
                           VerticalOptions="Start"/>
                    <Label Grid.Row="3" Grid.Column="1" 
                           x:Name="TemperamentLabel" 
                           FontSize="14"
                           TextColor="#8B7355"
                           VerticalOptions="Start" 
                           LineBreakMode="WordWrap"/>

                    <Label Grid.Row="4" Grid.Column="0" 
                           Text="⏳ Life Span:" 
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="#34495E"
                           VerticalOptions="Start"/>
                    <Label Grid.Row="4" Grid.Column="1" 
                           x:Name="LifeSpanLabel" 
                           FontSize="14"
                           TextColor="#8B7355"
                           VerticalOptions="Start"/>

                    <Label Grid.Row="5" Grid.Column="0" 
                           Text="↔️ Image Width:" 
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="#34495E"
                           VerticalOptions="Start"/>
                    <Label Grid.Row="5" Grid.Column="1" 
                           x:Name="WidthLabel" 
                           FontSize="14"
                           TextColor="#8B7355"
                           VerticalOptions="Start"/>

                    <Label Grid.Row="6" Grid.Column="0" 
                           Text="↕️ Image Height:" 
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="#34495E"
                           VerticalOptions="Start"/>
                    <Label Grid.Row="6" Grid.Column="1" 
                           x:Name="HeightLabel" 
                           FontSize="14"
                           TextColor="#8B7355"
                           VerticalOptions="Start"/>

                    <Label Grid.Row="7" Grid.Column="0" 
                           Text="💾 Local Only:" 
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="#34495E"
                           VerticalOptions="Start"/>
                    <Label Grid.Row="7" Grid.Column="1" 
                           x:Name="LocalOnlyLabel" 
                           FontSize="14"
                           TextColor="#8B7355"
                           VerticalOptions="Start"/>

                    <Label Grid.Row="8" Grid.Column="0" 
                           Text="📅 Created:" 
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="#34495E"
                           VerticalOptions="Start"/>
                    <Label Grid.Row="8" Grid.Column="1" 
                           x:Name="CreatedLabel" 
                           FontSize="14"
                           TextColor="#8B7355"
                           VerticalOptions="Start"/>

                </Grid>
            </Frame>

            <Frame CornerRadius="15" 
                   Padding="20" 
                   HasShadow="False" 
                   BackgroundColor="White"
                   BorderColor="Transparent">
                <VerticalStackLayout Spacing="10">
                    <Label Text="📝 Description:" 
                           FontAttributes="Bold" 
                           FontSize="18"
                           TextColor="#34495E"/>
                    <BoxView HeightRequest="1" 
                             BackgroundColor="#E0D5C7"
                             Margin="0,0,0,10"/>
                    <Label x:Name="DescriptionLabel" 
                           TextColor="#8B7355" 
                           FontSize="14"
                           LineBreakMode="WordWrap"/>
                </VerticalStackLayout>
            </Frame>

            <BoxView HeightRequest="20" Color="Transparent"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CatAPIfetcher.Views.SettingsPage"
             Title="Settings"
             BackgroundColor="#F5F5F5">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="⚙️ Settings" 
                   FontSize="32" 
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#2C3E50"
                   Margin="0,0,0,20"/>

            <Frame CornerRadius="15" 
                   Padding="20" 
                   HasShadow="False" 
                   BackgroundColor="White"
                   BorderColor="Transparent">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="15">
                    <VerticalStackLayout Grid.Column="0" Spacing="5">
                        <Label Text="💾 Show Local Cats in 'Cats' Tab" 
                               FontSize="16" 
                               FontAttributes="Bold"
                               TextColor="#34495E"/>
                        <Label Text="When enabled, locally added cats will appear in the main Cats list" 
                               FontSize="12" 
                               TextColor="#7F8C8D"
                               LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                    <Switch Grid.Column="1" 
                            x:Name="ShowLocalCatsSwitch"
                            IsToggled="True"
                            Toggled="OnShowLocalCatsToggled"
                            VerticalOptions="Center"
                            OnColor="#27AE60"/>
                </Grid>
            </Frame>

            <Frame CornerRadius="15" 
                   Padding="20" 
                   HasShadow="False" 
                   BackgroundColor="White"
                   BorderColor="Transparent">
                <VerticalStackLayout Spacing="15">
                    <Label Text="🎲 Cat Generator Settings" 
                           FontSize="18" 
                           FontAttributes="Bold"
                           TextColor="#34495E"/>

                    <BoxView HeightRequest="1" 
                             BackgroundColor="#ECF0F1"
                             Margin="0,0,0,10"/>

                    <Label Text="Number of cats to generate:" 
                           FontSize="14" 
                           FontAttributes="Bold"
                           TextColor="#34495E"/>

                    <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                        <Button Text="-" 
                                Clicked="OnDecreaseClicked"
                                WidthRequest="50"
                                HeightRequest="50"
                                FontSize="24"
                                BackgroundColor="#E74C3C"
                                TextColor="White"
                                CornerRadius="25"/>

                        <Frame CornerRadius="10" 
                               Padding="15,10" 
                               HasShadow="False"
                               BackgroundColor="#ECF0F1"
                               BorderColor="Transparent">
                            <Label x:Name="CountLabel"
                                   Text="10"
                                   FontSize="32"
                                   FontAttributes="Bold"
                                   TextColor="#2C3E50"
                                   WidthRequest="60"
                                   HorizontalTextAlignment="Center"/>
                        </Frame>

                        <Button Text="+" 
                                Clicked="OnIncreaseClicked"
                                WidthRequest="50"
                                HeightRequest="50"
                                FontSize="24"
                                BackgroundColor="#27AE60"
                                TextColor="White"
                                CornerRadius="25"/>
                    </HorizontalStackLayout>

                    <Label Text="Range: 1-50 cats" 
                           FontSize="12" 
                           TextColor="#7F8C8D"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <Button Text="🔄 Generate New Cats"
                    Clicked="OnGenerateClicked"
                    BackgroundColor="#3498DB"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    HeightRequest="60"
                    CornerRadius="15"
                    Margin="0,10,0,0"/>

            <Label Text="⚠️ This will delete only API cats and generate new random cats. Your local cats will be preserved."
                   FontSize="12"
                   TextColor="#27AE60"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap"
                   Margin="0,0,0,20"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
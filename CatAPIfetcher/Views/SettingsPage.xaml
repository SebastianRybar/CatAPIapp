<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CatAPIfetcher.Views.SettingsPage"
             Title="Settings"
             BackgroundColor="#F2F6FA">

    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="25">

            <Label Text="⚙️ Settings"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#1A1A1A"/>

            <Frame CornerRadius="16"
                   Padding="20"
                   BackgroundColor="White">

                <VerticalStackLayout Spacing="12">

                    <Label Text="💾 Show Local Cats"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="Black"/>

                    <Label Text="When enabled, locally added cats will appear in the main Cats list."
                           FontSize="13"
                           TextColor="#555"
                           LineBreakMode="WordWrap"/>

                    <Switch x:Name="ShowLocalCatsSwitch"
                            IsToggled="True"
                            Toggled="OnShowLocalCatsToggled"
                            OnColor="#27AE60"/>

                </VerticalStackLayout>
            </Frame>


            <Frame CornerRadius="16"
                   Padding="20"
                   BackgroundColor="White">

                <VerticalStackLayout Spacing="18">

                    <Label Text="🎲 Cat Generator"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="Black"/>

                    <Label Text="Number of cats:"
                           FontSize="14"
                           TextColor="Black"/>

                    <HorizontalStackLayout
                        HorizontalOptions="Center"
                        Spacing="20">

                        <Button Text="-"
                                Clicked="OnDecreaseClicked"
                                WidthRequest="50"
                                HeightRequest="50"
                                FontSize="22"
                                CornerRadius="25"
                                BackgroundColor="#E74C3C"
                                TextColor="White"/>

                        <Label x:Name="CountLabel"
                               Text="10"
                               FontSize="30"
                               FontAttributes="Bold"
                               WidthRequest="60"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center"
                               TextColor="Black"/>

                        <Button Text="+"
                                Clicked="OnIncreaseClicked"
                                WidthRequest="50"
                                HeightRequest="50"
                                FontSize="22"
                                CornerRadius="25"
                                BackgroundColor="#27AE60"
                                TextColor="White"/>

                    </HorizontalStackLayout>

                    <Label Text="Range: 1 - 50 cats"
                           FontSize="12"
                           TextColor="#666"
                           HorizontalOptions="Center"/>

                </VerticalStackLayout>
            </Frame>


            <Button Text="🔄 Generate New Cats"
                    Clicked="OnGenerateClicked"
                    HeightRequest="60"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="16"
                    BackgroundColor="#3498DB"
                    TextColor="White"/>


            <Label Text="⚠️ This will delete only API cats and generate new random cats. Your local cats will remain safe."
                   FontSize="12"
                   HorizontalTextAlignment="Center"
                   TextColor="#555"
                   LineBreakMode="WordWrap"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CatAPIfetcher.Views.MyCatsPage"
             Title="My Cats"
             BackgroundColor="#F5F5F5">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+" Clicked="OnAddCatClicked"/>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*,Auto">

        <CollectionView 
            Grid.Row="0"
            x:Name="MyCatsCollectionView"
            SelectionMode="None"
            Margin="10">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="15"/>
            </CollectionView.ItemsLayout>
            <CollectionView.EmptyView>
                <StackLayout Padding="20" VerticalOptions="Center">
                    <Label Text="🐱" 
                           FontSize="80" 
                           HorizontalOptions="Center"
                           Margin="0,0,0,20"/>
                    <Label Text="No cats added yet!" 
                           FontSize="24" 
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="#34495E"/>
                    <Label Text="Tap + to add your first cat" 
                           FontSize="16" 
                           HorizontalOptions="Center"
                           TextColor="#7F8C8D"
                           Margin="0,10,0,0"/>
                </StackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame CornerRadius="15" 
                           Padding="0" 
                           HasShadow="False" 
                           BackgroundColor="White"
                           BorderColor="Transparent"
                           Margin="5,0">
                        <Grid Padding="15" 
                              ColumnDefinitions="120,*,Auto" 
                              RowDefinitions="Auto,Auto,Auto"
                              ColumnSpacing="15"
                              RowSpacing="10">

                            <Frame Grid.Column="0" 
                                   Grid.RowSpan="3" 
                                   CornerRadius="12" 
                                   Padding="3" 
                                   HasShadow="False"
                                   BackgroundColor="#F5F5F5"
                                   BorderColor="Transparent"
                                   HeightRequest="120"
                                   WidthRequest="120">
                                <Image 
                                    Source="{Binding Url}"
                                    Aspect="AspectFit"/>
                            </Frame>

                            <Label Grid.Column="1" 
                                   Grid.Row="0"
                                   Text="{Binding DisplayName}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#2C3E50"
                                   VerticalOptions="End">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCatTapped" CommandParameter="{Binding}"/>
                                </Label.GestureRecognizers>
                            </Label>

                            <Label Grid.Column="1" 
                                   Grid.Row="1"
                                   Text="{Binding CreatedAt, StringFormat='Added: {0:dd/MM/yyyy HH:mm}'}"
                                   FontSize="12"
                                   TextColor="#7F8C8D"
                                   VerticalOptions="Start">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCatTapped" CommandParameter="{Binding}"/>
                                </Label.GestureRecognizers>
                            </Label>

                            <Frame Grid.Column="2" 
                                   Grid.Row="0"
                                   CornerRadius="8"
                                   Padding="8,4"
                                   HasShadow="False"
                                   BackgroundColor="#27AE60"
                                   BorderColor="Transparent"
                                   VerticalOptions="Start">
                                <Label Text="💾 Local"
                                       FontSize="11"
                                       TextColor="White"
                                       FontAttributes="Bold"/>
                            </Frame>

                            <Button Grid.Column="1" 
                                    Grid.ColumnSpan="2"
                                    Grid.Row="2"
                                    Text="🗑️ Delete"
                                    Clicked="OnDeleteClicked"
                                    CommandParameter="{Binding}"
                                    BackgroundColor="#E74C3C"
                                    TextColor="White"
                                    FontSize="14"
                                    FontAttributes="Bold"
                                    CornerRadius="8"
                                    HeightRequest="40"
                                    Margin="0,5,0,0"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator 
            Grid.Row="0"
            x:Name="LoadingIndicator"
            IsRunning="False"
            IsVisible="False"
            Color="#3498DB"
            VerticalOptions="Center"
            HorizontalOptions="Center"/>

    </Grid>

</ContentPage>
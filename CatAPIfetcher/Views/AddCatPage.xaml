<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CatAPIfetcher.Views.AddCatPage"
             Title="Add Cat"
             BackgroundColor="AliceBlue">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Frame CornerRadius="15" 
                   Padding="15" 
                   HasShadow="False" 
                   BackgroundColor="AliceBlue"
                   BorderColor="Transparent">
                <VerticalStackLayout Spacing="10">
                    <Label Text="📝 Basic Information" 
                           FontSize="18" 
                           FontAttributes="Bold"
                           TextColor="#2C3E50"/>
                    
                    <Label Text="Name *" FontSize="14" FontAttributes="Bold" TextColor="#34495E"/>
                    <Entry x:Name="NameEntry" 
                           Placeholder="Enter cat name"
                           BackgroundColor="#FFF8F0"
                           TextColor="#2C3E50"/>

                    <Label Text="Breed" FontSize="14" FontAttributes="Bold" TextColor="#34495E" Margin="0,10,0,0"/>
                    <Entry x:Name="BreedEntry" 
                           Placeholder="e.g., Persian, Siamese, Mixed"
                           BackgroundColor="#FFF8F0"
                           TextColor="#2C3E50"/>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="15" 
                   Padding="15" 
                   HasShadow="False" 
                   BackgroundColor="White"
                   BorderColor="Transparent">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🖼️ Image *" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50"/>

                    <Button Text="📷 Pick Image from Gallery" 
                            Clicked="OnPickImageClicked"
                            BackgroundColor="#3498DB"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="8"/>

                    <Frame x:Name="ImageFrame"
                           CornerRadius="12" 
                           Padding="5" 
                           HasShadow="False"
                           BackgroundColor="#FFF8F0"
                           BorderColor="#E0D5C7"
                           HeightRequest="200"
                           IsVisible="False">
                        <Image x:Name="PreviewImage" 
                               Aspect="AspectFit"/>
                    </Frame>

                    <Label x:Name="ImagePathLabel"
                           Text="No image selected"
                           FontSize="12"
                           TextColor="#8B7355"
                           HorizontalOptions="Center"/>

                    <Label x:Name="ImageDimensionsLabel"
                           Text=""
                           FontSize="12"
                           TextColor="#8B7355"
                           HorizontalOptions="Center"
                           IsVisible="False"/>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="15" 
                   Padding="15" 
                   HasShadow="False" 
                   BackgroundColor="White"
                   BorderColor="Transparent">
                <VerticalStackLayout Spacing="10">
                    <Label Text="ℹ️ Additional Details" 
                           FontSize="18" 
                           FontAttributes="Bold"
                           TextColor="#2C3E50"/>

                    <Label Text="Origin" FontSize="14" FontAttributes="Bold" TextColor="#34495E"/>
                    <Entry x:Name="OriginEntry" 
                           Placeholder="e.g., Egypt, Thailand, United States"
                           BackgroundColor="#FFF8F0"
                           TextColor="#2C3E50"/>

                    <Label Text="Temperament" FontSize="14" FontAttributes="Bold" TextColor="#34495E" Margin="0,10,0,0"/>
                    <Entry x:Name="TemperamentEntry" 
                           Placeholder="e.g., Playful, Calm, Friendly"
                           BackgroundColor="#FFF8F0"
                           TextColor="#2C3E50"/>

                    <Label Text="Life Span" FontSize="14" FontAttributes="Bold" TextColor="#34495E" Margin="0,10,0,0"/>
                    <Entry x:Name="LifeSpanEntry" 
                           Placeholder="e.g., 12-15 years"
                           BackgroundColor="#FFF8F0"
                           TextColor="#2C3E50"/>

                    <Label Text="Description" FontSize="14" FontAttributes="Bold" TextColor="#34495E" Margin="0,10,0,0"/>
                    <Editor x:Name="DescriptionEditor" 
                            Placeholder="Enter description (optional)"
                            HeightRequest="100"
                            BackgroundColor="#FFF8F0"
                            TextColor="#2C3E50"/>
                </VerticalStackLayout>
            </Frame>

            <Label Text="* Required fields" 
                   FontSize="12" 
                   TextColor="#E74C3C"
                   HorizontalOptions="Start"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,20">
                <Button Text="💾 Save" 
                        Clicked="OnSaveClicked"
                        BackgroundColor="#27AE60"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="8"
                        HeightRequest="50"
                        Grid.Column="0"/>

                <Button Text="❌ Cancel" 
                        Clicked="OnCancelClicked"
                        BackgroundColor="#95A5A6"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="8"
                        HeightRequest="50"
                        Grid.Column="1"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
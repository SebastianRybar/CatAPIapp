<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CatAPIfetcher.Views.AddCatPage"
             Title="Add Cat">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Name" FontSize="16" FontAttributes="Bold"/>
            <Entry x:Name="NameEntry" Placeholder="Enter cat name"/>

            <Label Text="Image URL" FontSize="16" FontAttributes="Bold"/>
            <Entry x:Name="UrlEntry" Placeholder="Enter image URL"/>

            <Button Text="Preview Image" 
                    Clicked="OnPreviewClicked"
                    BackgroundColor="{StaticResource Secondary}"
                    TextColor="White"/>

            <Image x:Name="PreviewImage" 
                   HeightRequest="200"
                   Aspect="AspectFit"
                   Margin="0,10"/>

            <Label Text="Description" FontSize="16" FontAttributes="Bold"/>
            <Editor x:Name="DescriptionEditor" 
                    Placeholder="Enter description (optional)"
                    HeightRequest="100"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,20,0,0">
                <Button Text="Save" 
                        Clicked="OnSaveClicked"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        Grid.Column="0"/>

                <Button Text="Cancel" 
                        Clicked="OnCancelClicked"
                        BackgroundColor="Gray"
                        TextColor="White"
                        Grid.Column="1"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CatAPIfetcher.Views.CatDetailPage"
             Title="Cat Detail">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Frame CornerRadius="15" Padding="0" HasShadow="True">
                <Image 
                    x:Name="CatImage"
                    Aspect="AspectFill"
                    HeightRequest="400"/>
            </Frame>

            <Label x:Name="CatNameLabel"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>

            <Grid ColumnDefinitions="Auto,*" RowSpacing="10" ColumnSpacing="10">

                <Label Grid.Row="0" Grid.Column="0" Text="ID:" FontAttributes="Bold"/>
                <Label Grid.Row="0" Grid.Column="1" x:Name="IdLabel"/>

                <Label Grid.Row="1" Grid.Column="0" Text="Width:" FontAttributes="Bold"/>
                <Label Grid.Row="1" Grid.Column="1" x:Name="WidthLabel"/>

                <Label Grid.Row="2" Grid.Column="0" Text="Height:" FontAttributes="Bold"/>
                <Label Grid.Row="2" Grid.Column="1" x:Name="HeightLabel"/>

                <Label Grid.Row="3" Grid.Column="0" Text="Local Only:" FontAttributes="Bold"/>
                <Label Grid.Row="3" Grid.Column="1" x:Name="LocalOnlyLabel"/>

                <Label Grid.Row="4" Grid.Column="0" Text="Created:" FontAttributes="Bold"/>
                <Label Grid.Row="4" Grid.Column="1" x:Name="CreatedLabel"/>

            </Grid>

            <Label Text="Description:" FontAttributes="Bold" FontSize="18" Margin="0,10,0,0"/>
            <Label x:Name="DescriptionLabel" TextColor="Gray"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>